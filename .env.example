# Copy this file to `.env` and fill in your real values.
#
# The repo default is OpenAI for intelligence tasks and `gpt-5.4` as the
# preferred model alias. If your runtime uses a different public model alias,
# override `AUTORESEARCH_INTELLIGENCE_MODEL` in `.env`.

AUTORESEARCH_INTELLIGENCE_PROVIDER=openai
AUTORESEARCH_INTELLIGENCE_MODEL=gpt-5.4

# Required for OpenAI-backed intelligence.
OPENAI_API_KEY=your_openai_api_key_here

# Optional overrides.
# OPENAI_BASE_URL=
